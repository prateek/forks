#!/usr/bin/env bash
#
# sync-fork-secrets — seed or rotate the fleet secrets on prateek/forks from the
# gh-prateek-fork-automation 1Password vault, non-interactively.
#
# CI never talks to 1Password (see AGENTS.md); this is a local operator tool. A
# 1Password service account scoped read-only to that one vault reads the values,
# and `gh secret set` writes them to the repo. The three secrets are
# repo-level — every per-tool workflow shares them — so adding a fork does NOT
# need new secrets. This is a seed-once / rotate-occasionally tool.
#
# Auth: a service-account token, taken from OP_SERVICE_ACCOUNT_TOKEN if set,
# otherwise from the login keychain item $OP_SA_KEYCHAIN_ITEM
# (default: op-fork-automation-sa). Store it once with:
#
#   security add-generic-password -a "$USER" -s op-fork-automation-sa -w
#   # paste the token at the prompt; -w with no value never echoes it
#
# Neither the token nor any secret value is ever printed.
#
# Usage: scripts/sync-fork-secrets [repo]     (default repo: prateek/forks)
set -euo pipefail

repo="${1:-prateek/forks}"
keychain_item="${OP_SA_KEYCHAIN_ITEM:-op-fork-automation-sa}"

if [ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
  if token="$(security find-generic-password -a "$USER" -s "$keychain_item" -w 2>/dev/null)"; then
    export OP_SERVICE_ACCOUNT_TOKEN="$token"
  else
    cat >&2 <<MSG
sync-fork-secrets: no service-account token found.
Set OP_SERVICE_ACCOUNT_TOKEN, or store it in the login keychain:
  security add-generic-password -a "\$USER" -s ${keychain_item} -w
MSG
    exit 2
  fi
fi

set_secret() {
  local name="$1" ref="$2" val
  val="$(op read "$ref")" || { printf 'sync-fork-secrets: op read failed for %s (%s)\n' "$name" "$ref" >&2; exit 1; }
  [ -n "$val" ] || { printf 'sync-fork-secrets: empty value for %s\n' "$name" >&2; exit 1; }
  printf '%s' "$val" | gh secret set "$name" --repo "$repo"
}

set_secret CLAUDE_CODE_OAUTH_TOKEN 'op://gh-prateek-fork-automation/claude/oauth-token'
set_secret FORK_APP_ID             'op://gh-prateek-fork-automation/prateek-fork-automation/app-id'
set_secret FORK_APP_PRIVATE_KEY    'op://gh-prateek-fork-automation/prateek-fork-automation/private-key'
printf 'synced 3 secrets to %s\n' "$repo"
